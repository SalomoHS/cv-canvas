generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String   @id @default(uuid())
  name      String   @default("")
  phone     String   @default("")
  email     String   @default("")
  location  String   @default("")
  links     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Summary {
  id        String   @id @default(uuid())
  name      String   @default("")
  content   String   @default("")
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Entry {
  id        String   @id @default(uuid())
  section   String
  subType   String?
  status    String   @default("library")
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Crate {
  id        String      @id @default(uuid())
  name      String
  versions  CVVersion[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model CVVersion {
  id                String   @id @default(uuid())
  name              String
  crateId           String?
  crate             Crate?   @relation(fields: [crateId], references: [id], onDelete: SetNull)
  entryIds          Json     @default("[]")
  sectionOrder      Json     @default("{}")
  skillOrder        Json     @default("[]")
  selectedSummaryId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
